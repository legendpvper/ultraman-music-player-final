<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/playerToolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/ultraman_dark"
            app:navigationIcon="@drawable/ic_arrow_back"/>
    </com.google.android.material.appbar.AppBarLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <!-- Colour header / album art -->
        <LinearLayout
            android:id="@+id/playerHeader"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@color/ultraman_blue">
            <TextView
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:gravity="center"
                android:text="U"
                android:textSize="60sp"
                android:textStyle="bold"
                android:textColor="#44FFFFFF"
                android:background="@drawable/circle_button_bg"/>
        </LinearLayout>

        <!-- Song info -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@android:color/white"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="16dp"
            android:paddingBottom="8dp">

            <TextView
                android:id="@+id/trackCounterText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/ultraman_blue"
                android:textSize="12sp"
                android:text="1 / 32"/>
            <TextView
                android:id="@+id/songTitleText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/ultraman_dark"
                android:layout_marginTop="4dp"
                android:text="Song Title"/>
            <TextView
                android:id="@+id/songSeriesText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textColor="@color/ultraman_blue"
                android:layout_marginTop="2dp"
                android:text="Series (Year)"/>
            <TextView
                android:id="@+id/songArtistText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textColor="#666666"
                android:layout_marginTop="2dp"
                android:text="Artist"/>
        </LinearLayout>

        <!-- Seek bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@android:color/white"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp">

            <SeekBar
                android:id="@+id/seekBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:progressTint="@color/ultraman_blue"
                android:thumbTint="@color/ultraman_blue"
                android:max="100"/>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView
                    android:id="@+id/currentTimeText"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textSize="12sp"
                    android:textColor="#888"
                    android:text="0:00"/>
                <TextView
                    android:id="@+id/durationText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="#888"
                    android:text="0:00"/>
            </LinearLayout>
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"/>

        <!-- Controls -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@android:color/white"
            android:paddingBottom="32dp"
            android:paddingTop="16dp">

            <!-- Play controls row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">

                <ImageButton
                    android:id="@+id/prevButton"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_prev"
                    android:tint="@color/ultraman_dark"
                    android:contentDescription="Previous"/>

                <ImageButton
                    android:id="@+id/playPauseButton"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:layout_marginStart="24dp"
                    android:layout_marginEnd="24dp"
                    android:background="@drawable/circle_button_bg"
                    android:src="@drawable/ic_play_large"
                    android:tint="@android:color/white"
                    android:contentDescription="Play/Pause"/>

                <ImageButton
                    android:id="@+id/nextButton"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_next"
                    android:tint="@color/ultraman_dark"
                    android:contentDescription="Next"/>
            </LinearLayout>

            <!-- Queue controls row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="12dp">

                <ImageButton
                    android:id="@+id/addToQueueButton"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginEnd="24dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_next"
                    android:tint="@color/ultraman_blue"
                    android:contentDescription="Add to queue"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:text="Add to Queue"
                    android:textSize="12sp"
                    android:textColor="@color/ultraman_blue"/>

                <ImageButton
                    android:id="@+id/viewQueueButton"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginStart="24dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_next"
                    android:tint="@color/ultraman_dark"
                    android:contentDescription="View queue"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="View Queue"
                    android:textSize="12sp"
                    android:textColor="@color/ultraman_dark"/>

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
